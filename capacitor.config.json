{
  "appId": "com.mathi.vetsafe",
  "appName": "VetSafe Tracker",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "cleartext": true
  },
  "plugins": {
    "SpeechRecognition": {
      "language": "en-US",
      "matches": 5,
      "prompt": "Say something",
      "showPopup": true,
      "showPartial": false
    },
    "TextToSpeech": {
      "language": "en-US",
      "rate": 1.0,
      "pitch": 1.0,
      "volume": 1.0
    }
  }
}
